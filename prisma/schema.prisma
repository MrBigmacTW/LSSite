generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id              String    @id @default(cuid())
  title           String
  description     String?
  tags            String    @default("[]") // JSON array: ["street", "minimal"]
  designImage     String    // 原始設計圖路徑
  mockups         String    @default("[]") // JSON array: [{ template, path }]
  price           Int       @default(1280) // 售價（NT$）
  sku             String?
  status          String    @default("pending_review")
  // status: draft | pending_review | published | rejected | archived
  rejectionReason String?
  source          String    // "manual" | "lobster"
  aiMetadata      String?   // JSON: { prompt, model, seed, style, generated_at }
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  publishedAt     DateTime?
}

model User {
  id           String @id @default(cuid())
  username     String @unique
  passwordHash String
  role         String @default("editor") // admin | editor
}

model ApiKey {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String   // "lobster-artist-prod"
  permissions String   @default("[\"create\",\"read\"]") // JSON array
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Order {
  id          String      @id @default(cuid())
  orderNo     String      @unique
  items       OrderItem[]
  name        String
  phone       String
  email       String
  address     String
  status      String      @default("pending")
  // pending | paid | shipped | completed | cancelled
  totalAmount Int
  paymentType String?
  tradeNo     String?
  paidAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id])
  productId String
  title     String
  size      String
  quantity  Int
  price     Int
  mockupUrl String?
}

model MockupTemplate {
  id        String  @id @default(cuid())
  name      String  // "短袖 T-shirt 正面"
  slug      String  @unique // "short_sleeve_front"
  category  String  // "short_sleeve" | "long_sleeve" | "hoodie"
  imagePath String  // 模板底圖路徑
  printArea String  // JSON: { x, y, width, height, rotation }
  active    Boolean @default(true)
  sortOrder Int     @default(0)
}
