# ── 資料庫 ──
DATABASE_URL="file:./prisma/dev.db"
# 線上：Turso libSQL
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Next-Auth ──
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL="http://localhost:3000"

# ── 檔案儲存 ──
# 設定後自動切換成 Vercel Blob；未設定走本機 public/uploads
BLOB_READ_WRITE_TOKEN=

# ── Email（Resend）──
RESEND_API_KEY=
FROM_EMAIL="onboarding@resend.dev"

# ── 藍新金流 ──
NEWEBPAY_MERCHANT_ID=
NEWEBPAY_HASH_KEY=
NEWEBPAY_HASH_IV=
NEWEBPAY_ENV="test"   # test | production

# ── AI 服務 ──
OPENROUTER_API_KEY=
# 龍蝦藝術家 Agent（lobster-artist/）也用到的 KIE
KIE_API_KEY=

# ── GitHub Actions 觸發 ──
GITHUB_TOKEN=
TRIGGER_SECRET="lobster-go"

# ── 站台 URL ──
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ──────────────────────────────────────────
# Studio POC（/studio-poc）
# ──────────────────────────────────────────
# URL key 閘門：訪問 /studio-poc?key=lw2026 才放行
POC_ACCESS_KEY="lw2026"
# 全站每日生圖總數上限（安全網，超過回 429）
POC_DAILY_GENERATION_LIMIT="100"
